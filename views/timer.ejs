<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/timer.css" />
  </head>
  <body class="app-page timer-page">
    <div class="app-shell">
      <main class="app-screen timer-screen">
        <section class="app-back-controls" aria-label="Navigation controls">
          <a
            href="/activities/continue"
            class="app-back-button"
            aria-label="Back"
          >
            <img src="/image/back-button.svg" alt="" width="52" height="52" />
          </a>
        </section>

        <section class="timer-content" aria-labelledby="timer-activity-title">
          <section class="timer-activity-summary" aria-label="Current activity">
            <span class="timer-category-icon">
              <img src="<%= activityIcon %>" alt="" />
            </span>
            <div class="timer-activity-text">
              <h2 id="timer-activity-title"><%= activityName %></h2>
              <p><%= category %></p>
            </div>
          </section>

          <section class="timer-clock" aria-label="Timer clock">
            <p id="timer-display"><%= timerValue %></p>
          </section>

          <section class="timer-actions" aria-label="Timer actions">
            <button
              type="button"
              id="timer-toggle-btn"
              class="timer-toggle-btn"
              aria-pressed="false"
            >
              <img id="timer-toggle-icon" src="/image/start.svg" alt="" />
              <span id="timer-toggle-label">Start</span>
            </button>

            <form
              id="timer-stop-form"
              action="/activities/summary"
              method="post"
            >
              <input
                type="hidden"
                name="activityId"
                value="<%= activityId || '' %>"
              />
              <input
                type="hidden"
                name="activityName"
                value="<%= activityName %>"
              />
              <input type="hidden" name="category" value="<%= category %>" />
              <input
                type="hidden"
                id="session-time-input"
                name="sessionTime"
                value="<%= timerValue %>"
              />
              <button type="submit" class="timer-stop-btn">Stop</button>
            </form>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/page-timer.js"></script>
  </body>
</html>
